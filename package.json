  "name": "tswebapp",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "mithril": "^2.3.8"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/mithril": "^2.2.8",
    "@types/node": "^25.5.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "dev:server": "nodemon src/server.ts",
    "dev:client": "esbuild src/ui/index.ts --bundle --outfile=public/bundle.js --watch",
    "dev:tailwind": "tailwindcss -i ./src/ui/tailwind.css -o ./public/tailwind.css --watch",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:tailwind\"",
    "build": "tsc && esbuild src/ui/index.ts --bundle --outfile=public/bundle.js",
    "start": "node dist/server.js"
  }
}
